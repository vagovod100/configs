{
	"layer": "top",
	"position": "top",
	"margin-bottom": 0,
	"modules-left": [
		"hyprland/workspaces",
		"hyprland/window"
	],
	"modules-center": [
		"clock",
	],
	"modules-right": [
		"tray",
		"network",
		"pulseaudio",
		"hyprland/language",
		"battery",
		"custom/powermenu"
	],
	"tray": {
		"spacing": 10
	},
	"hyprland/language":{
		"format": "ΎΕε  {short}"
	},
	"hyprland/window": {
		"format": "{initialTitle}",
		"rewrite": {
			"": "Hyprland"
		},
		"separate-outputs": false
	},
	"battery": {
		"format": "{icon} {capacity}%",
        	"format-icons": {
            		"charging": [
                		"≤░λε",
                		"≤░ΓΗ",
                		"≤░ΓΘ",
                		"≤░ΓΙ",
                		"≤░λζ",
                		"≤░ΓΚ",
                		"≤░λη",
                		"≤░ΓΛ",
                		"≤░ΓΜ",
                		"≤░ΓΖ"
            		],
            		"default": [
                		"≤░Β║",
                		"≤░Β╗",
                		"≤░Β╝",
                		"≤░Β╜",
                		"≤░Β╛",
                		"≤░Β┐",
                		"≤░ΓΑ",
                		"≤░ΓΒ",
                		"≤░ΓΓ",
                		"≤░Β╣"
            		]
        	},
        "format-full": "Charged ΎΔπ",
        "interval": 5,
        "states": {
            "warning": 20,
            "critical": 10
        },
        "tooltip": false
    },
    "hyprland/workspaces": {
      "format": "{icon}",
      "format-icons": {
        "1": "≤░▓ι",
        "2": "≤░▓λ",
        "3": "≤░▓ν",
        "4": "≤░▓ο",
        "5": "≤░▓ρ",
        "6": "≤░▓ς",
        "7": "≤░▓υ",
        "8": "≤░▓χ",
        "9": "≤░▓░",
        "10": "≤░┐υ",
        "-99": "Όυμ",
        "active": "ΎΕΣ",
        "default": "ΎΕΝ"
      }
    },
    "network": {
	"tooltip-format-ethernet": "{ifname} ΎΔΒ",
	"interval": 2,
	"format": "ΎΘτ  {signalStrength}%"
    },
    "temperature": {
	"thermal-zone": 1,
	"format": "{icon} {temperatureC}┬░C",
	"critical-threshold": 80,
	"format-icons": ["ΎΜΜ", "ΎΜΚ", "ΎΜΘ"]
    },
    "memory": {
      "format": " ΎΦ╕ {}%",
      "tooltip": "false"
    },
    "cpu": {
      "format": "ΌΚο {usage}%",
      "tooltip": "false"
    },
    "custom/powermenu": {
      "format": "ΎΑΣ",
      "tooltip": false,
      "on-click": "exec wlogout",
    },
    "pulseaudio": {
      "format": "{icon}  {volume}%",
      "format-bluetooth": "{icon} ΎΛΦ  {volume}%",
      "format-muted": "ΎΑο",
      "format-icons": {
          "headphone": "ΎΑξ",
          "hands-free": "ΎΨΡ",
          "headset": "ΎΨΡ",
          "phone": "ΎΓΧ",
          "portable": "ΎΓΧ",
          "car": "ΎΗ╣",
          "default": ["ΎΑπ", "ΎΑρ"]
      },
      "scroll-step": 1,
      "on-click": "pavucontrol"
    },
    "clock": {
      "format": "{:%H:%M}",
      "interval": 60,
      "tooltip": true,
      "tooltip-format": "{:%d %B %H:%M}"
    }
}
